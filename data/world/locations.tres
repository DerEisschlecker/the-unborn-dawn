[gd_resource type="Resource" script_class="CatalogData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/resources/catalog_data.gd" id="1"]

[resource]
script = ExtResource("1")
entries = {
"base": {"name": "Zuflucht Morgenrot", "type": "Basis", "danger": 0, "travel": 0, "description": "Ein alter Strassenbahndepot, notduerftig befestigt.", "loot": [], "background": "res://assets/environments/base_scenes/base_evening_painted.png"},
"harbor_pier": {"name": "Schwarzpier", "type": "Event", "danger": 2, "travel": 1, "description": "Ein alter Kai mit Bootsrippen, rostigen Ketten und einer halb sicheren Route.", "loot": ["clean_water", "rainwater", "wood", "cloth", "signal_flare"], "background": "res://assets/environments/backgrounds/menu_ruins.png"},
"drowned_quay": {"name": "Ertrunkener Kai", "type": "Kuestenruine", "danger": 2, "travel": 1, "description": "Ueberflutete Strassen und nasse Keller, gut fuer Wasser und alte Vorratskisten.", "loot": ["rainwater", "clean_water", "canned_beans", "cloth", "flashlight_battery"], "background": "res://assets/environments/backgrounds/menu_ruins.png"},
"radio_tower": {"name": "Funkturm Nord", "type": "Versteckter Ort", "danger": 3, "travel": 2, "description": "Ein schwaches Notsignal wiederholt drei Woerter: Noch nicht geboren.", "loot": ["revolver_ammo", "clean_water", "metal", "electronics"], "hidden": true, "background": "res://assets/environments/backgrounds/military_painted.png"},
"ruined_town": {"name": "Altstadt-Ruinen", "type": "Stadt", "danger": 2, "travel": 1, "description": "Leere Haeuser, zerbrochene Fenster und zurueckgelassene Vorraete.", "loot": ["canned_beans", "canned_peaches", "energy_bar", "clean_water", "cloth", "nails", "flashlight_battery", "scavenger_pack", "patched_jacket", "wire_ring", "leather_belt"], "background": "res://assets/environments/backgrounds/menu_ruins.png"},
"withered_gate": {"name": "Welkes Tor", "type": "Event", "danger": 2, "travel": 1, "description": "Ein verrostetes Tor sperrt den alten Suedweg. Dahinter liegt ein reparierbarer Zugang.", "loot": ["nails", "wood", "metal", "bandage"], "background": "res://assets/environments/backgrounds/factory_painted.png"},
"ash_market": {"name": "Aschemarkt", "type": "Haendler", "danger": 1, "travel": 1, "description": "Ein wandernder Markt hinter Planen, Lampen und sehr vielen Augen.", "loot": ["clean_water", "bandage", "revolver_ammo", "metal", "cloth"], "background": "res://assets/environments/backgrounds/menu_ruins.png"},
"factory": {"name": "Grauguss-Werk", "type": "Industrie", "danger": 3, "travel": 2, "description": "Rostige Hallen voller Metall und langer Schatten.", "loot": ["metal", "nails", "powder", "fuel", "electronics", "work_gloves", "fire_axe"], "background": "res://assets/environments/backgrounds/factory_painted.png"},
"cinder_works": {"name": "Zunderwerke", "type": "Industrie", "danger": 3, "travel": 1, "description": "Ein Nebenwerk mit warmen Schlackeloechern, Werkzeugschraenken und viel Staub.", "loot": ["metal", "powder", "fuel", "electronics", "work_gloves", "crowbar"], "background": "res://assets/environments/backgrounds/factory_painted.png"},
"chapel": {"name": "Versunkene Kapelle", "type": "Versteckter Ort", "danger": 4, "travel": 2, "description": "Unter dem Altar fluestert etwas in einer toten Sprache.", "loot": ["cleansing_salt", "herbs", "cloth", "respirator_mask", "salt_amulet", "warding_amulet"], "hidden": true, "background": "res://assets/environments/backgrounds/forest_painted.png"},
"silent_monastery": {"name": "Stilles Kloster", "type": "Event", "danger": 3, "travel": 1, "description": "Ein leerer Kreuzgang mit eingeritzten Wegzeichen und getrocknetem Blut.", "loot": ["cleansing_salt", "bandage", "herbs", "antiseptic"], "background": "res://assets/environments/backgrounds/forest_painted.png"},
"forest": {"name": "Schwarzkiefernwald", "type": "Wald", "danger": 2, "travel": 1, "description": "Zwischen den Staemmen wachsen noch Heilkraeuter.", "loot": ["wood", "herbs", "clean_water", "rainwater", "salt", "hiker_backpack", "work_boots"], "background": "res://assets/environments/backgrounds/forest_painted.png"},
"grave_crossroads": {"name": "Graskreuzung", "type": "Event", "danger": 2, "travel": 1, "description": "Ein Wegkreuz voller Zettel, Strichmarken und alter Frequenzen.", "loot": ["radio_parts", "flashlight_battery", "cloth", "energy_bar"], "background": "res://assets/environments/backgrounds/forest_painted.png"},
"black_forge": {"name": "Schwarze Schmiede", "type": "Dungeon", "danger": 4, "travel": 2, "description": "Eine versiegelte Werkhalle. Drinnen liegen Werkzeuge, Waffen und schlechte Luft.", "loot": ["metal", "fuel", "electronics", "machete", "fire_axe", "leather_vest"], "background": "res://assets/environments/backgrounds/factory_painted.png"},
"collapsed_bridge": {"name": "Eingestuerzte Bruecke", "type": "Event", "danger": 2, "travel": 1, "description": "Der alte Uebergang ist weg. Mit Material kann hier ein neuer Pfad entstehen.", "loot": ["wood", "metal", "nails", "fuel"], "background": "res://assets/environments/backgrounds/factory_painted.png"},
"signal_observatory": {"name": "Observatorium", "type": "Event", "danger": 3, "travel": 2, "description": "Eine alte Sternwarte, deren Antennen nachts noch Antworten finden.", "loot": ["radio_parts", "flashlight_battery", "electronics", "clean_water"], "background": "res://assets/environments/backgrounds/military_painted.png"},
"hospital": {"name": "St.-Mara-Klinik", "type": "Krankenhaus", "danger": 3, "travel": 2, "description": "Die Notaufnahme ist gepluendert, aber nicht leer.", "loot": ["bandage", "antibiotics", "cloth", "painkillers", "antiseptic", "scavenger_pack", "respirator_mask", "salt_amulet"], "background": "res://assets/environments/backgrounds/hospital_painted.png"},
"cathedral_gate": {"name": "Kathedralentor", "type": "Dungeon", "danger": 4, "travel": 2, "description": "Ein riesiges Tor unter roten Fenstern. Dahinter warten Reliquien und Wachposten.", "loot": ["cleansing_salt", "service_pistol", "revolver_ammo", "scrap_helmet", "antiseptic", "signet_ring", "scrap_shield"], "background": "res://assets/environments/backgrounds/hospital_painted.png"},
"military": {"name": "Kontrollpunkt Echo", "type": "Militaerposten", "danger": 4, "travel": 3, "description": "Verlassene Sandsaecke und verschlossene Munitionskisten.", "loot": ["revolver_ammo", "rifle_ammo", "shotgun_shell", "powder", "leather_vest", "pump_shotgun", "military_rucksack", "scrap_helmet", "reinforced_pants", "scrap_shield", "reinforced_shield"], "background": "res://assets/environments/backgrounds/military_painted.png"},
"old_bunker": {"name": "Bunker unter dem Wall", "type": "Dungeon", "danger": 5, "travel": 2, "description": "Eine versiegelte Anlage unter Beton, Funkrauschen und Kratzspuren.", "loot": ["rifle_ammo", "electronics", "scoped_sniper", "antibiotics", "leather_vest", "reinforced_belt", "reinforced_shield"], "background": "res://assets/environments/backgrounds/military_painted.png"},
"eastern_pass": {"name": "Ostpass", "type": "Event", "danger": 4, "travel": 2, "description": "Eine schmale Strasse durch tote Vororte. Nur starke Gruppen kommen heil zurueck.", "loot": ["rifle_ammo", "clean_water", "dried_meat", "signal_flare"], "background": "res://assets/environments/backgrounds/military_painted.png"},
"watchtower": {"name": "Wachtturm Weiss", "type": "Aussenposten", "danger": 4, "travel": 1, "description": "Ein hoher Turm mit klarer Sicht und verschlossenen Versorgungsschranken.", "loot": ["electronics", "rifle_ammo", "hunting_rifle", "work_boots", "radio_parts"], "background": "res://assets/environments/backgrounds/military_painted.png"},
"south_roadblock": {"name": "Suedblockade", "type": "Event", "danger": 3, "travel": 1, "description": "Ein umgekippter Konvoi mit einem noch brauchbaren Schluesselkasten.", "loot": ["metal", "fuel", "revolver_ammo", "bandage", "frag_grenade"], "background": "res://assets/environments/backgrounds/military_painted.png"},
"sealed_metro": {"name": "Versiegelte Metro", "type": "Dungeon", "danger": 5, "travel": 2, "description": "Ein Tunnelnetz unter der Stadt. Die Tore brauchen Strom und Werkzeug.", "loot": ["powder", "electronics", "compact_smg", "shotgun_shell", "cleansing_salt"], "background": "res://assets/environments/backgrounds/menu_ruins.png"}
}
